{
  "name": "expense-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "Mobile-first expense tracker backed by Google Sheets",
  "scripts": {
    "lint": "eslint js/ config.js",
    "lint:fix": "eslint js/ config.js --fix",
    "test": "jest --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "jest": "^29.0.0",
    "lint-staged": "^15.0.0"
  },
  "lint-staged": {
    "js/**/*.js": "eslint --fix",
    "config.js": "eslint --fix"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "js/i18n.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 30
      }
    },
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "testMatch": [
      "**/js/__tests__/**/*.test.js"
    ]
  }
}
